{
  "name": "cobach/almacen-escolar",
  "description": "Sistema Institucional de Almacén Escolar — Colegio de Bachilleres del Estado de Durango",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "phpmailer/phpmailer": "^6.9",
    "phpoffice/phpspreadsheet": "^3.3",
    "mpdf/mpdf": "^8.2",
    "endroid/qr-code": "^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
