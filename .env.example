# ============================================================
# SISTEMA INSTITUCIONAL DE ALMACÉN ESCOLAR
# Archivo de configuración de entorno
# NUNCA subir el .env real al repositorio
# ============================================================

# --- APLICACIÓN ---
APP_NAME="Sistema de Almacén Escolar"
APP_ENV=local
APP_DEBUG=true
APP_URL=
APP_TIMEZONE=America/Mexico_City

# --- BASE DE DATOS ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=almacen_escolar
DB_USER=root
DB_PASS=

# --- SESIONES ---
SESSION_NAME=almacen_session
SESSION_LIFETIME=7200
SESSION_SECURE=false

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_ALLOWED_DOMAIN=

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME="Almacén Escolar"
SMTP_FROM_EMAIL=

# --- WHATSAPP (API) ---
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=

# --- INSTITUCIÓN ---
INST_NOMBRE=""
INST_AREA=""
INST_DIRECTOR=
INST_DIRECTOR_ADMIN=
INST_JEFE_RECURSOS=
INST_WHATSAPP=
INST_LOGO=assets/img/logo.png

# --- SEGURIDAD ---
CSRF_SECRET=CAMBIAR_POR_CLAVE_ALEATORIA_256BITS
ENCRYPTION_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_256BITS

# --- RUTAS DE ALMACENAMIENTO ---
STORAGE_TEMP=storage/temp/
STORAGE_EXPORTS=storage/exports/
STORAGE_QR=storage/qr/
LOG_PATH=logs/

# --- PAGINACIÓN ---
ITEMS_PER_PAGE=25
